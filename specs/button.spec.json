  "variants": {
    "type":    { "values": ["contained", "outlined", "ghost"],                                        "default": "contained" },
    "size":    { "values": ["s", "m", "l"],                                                           "default": "m" },
    "state":   { "values": ["idle", "hover", "pressed", "focused", "disabled", "loading"],            "default": "idle" },
    "inverse": { "values": ["no", "yes"],                                                             "default": "no", "generate_by_default": false }
  },

  "naming": {
    "component_set": "button",
    "variant_format": "size={size}, type={type}, state={state}, inverse={inverse}"
  },

  "anatomy": {
    "layers": ["Container", "Icon L", "Label", "Icon R", "Spinner"],
    "layout": "horizontal, center-aligned, fixed height",
    "gap": 4,
    "component_properties": [
      { "name": "Label",       "type": "TEXT",          "default": "Button",            "bound_layer": "Label" },
      { "name": "Show icon L", "type": "BOOLEAN",       "default": false,               "bound_layers": ["Icon L"] },
      { "name": "Icon L",      "type": "INSTANCE_SWAP", "default_component": "icons/placeholder", "preferred_set": "icons", "bound_layer": "Icon L" },
      { "name": "Show icon R", "type": "BOOLEAN",       "default": false,               "bound_layers": ["Icon R"] },
      { "name": "Icon R",      "type": "INSTANCE_SWAP", "default_component": "icons/placeholder", "preferred_set": "icons", "bound_layer": "Icon R" }
    ],
    "notes": "Spinner (20px) replaces Label + Icon L + Icon R in loading state."
  },

  "sizing": {
    "s": { "height": 32, "min_width": 60,  "paddingX": 12, "paddingY": 9,  "paddingY_loading": 6  },
    "m": { "height": 40, "min_width": 80,  "paddingX": 16, "paddingY": 12, "paddingY_loading": 10 },
    "l": { "height": 48, "min_width": 100, "paddingX": 20, "paddingY": 16, "paddingY_loading": 14 }
  },

  "typography": {
