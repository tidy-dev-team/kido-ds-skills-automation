      "focused":  "system/fg/primary",
      "disabled": "system/fg/disabled"
    },
    "indeterminate": {
      "idle":     "system/fg/primary",
      "hover":    "system/fg/primary + overlay-hover-on-color",
      "pressed":  "system/fg/active",
      "focused":  "system/fg/primary",
      "disabled": "system/fg/disabled"
    }
  },

  "accessibility": {
    "min_touch_target": 44,
    "focus_ring": {
      "width_token": "width/thick",
      "width": 2,
      "color_token": "system/border/interactive/focused",
      "placement": "border on icon container",
      "radius_s": 2,
      "radius_m": 4
