    "selection type": { "values": ["unchecked", "checked", "indeterminate"],              "default": "unchecked" }
  },

  "naming": {
    "component_set": "checkbox-1",
    "variant_format": "size={size}, state={state}, selection type={selection type}"
  },

  "anatomy": {
    "layers": ["check_box_outlined_blank", "check_box", "indeterminate_check_box"],
    "layout": "single icon, fixed square, centered",
    "gap": null,
    "notes": "One icon layer is visible at a time — swapped per selection type. Icons are Material Symbols Outlined (Google Fonts). Each icon is rendered at 75% of the container (inset 12.5%). No background fill on the root — the icon itself carries the background color (baked into the SVG for checked/indeterminate). Focus ring is a 2px border applied to the icon container in focused state."
  },

  "sizing": {
    "s": { "height": 16, "width": 16, "min_width": null, "paddingX": 0, "paddingY": 0 },
    "m": { "height": 20, "width": 20, "min_width": null, "paddingX": 0, "paddingY": 0 }
  },

  "typography": null,

  "border_radius": {
    "s": { "token": "radius/semantic/tiny-elements",  "value": 2 },
    "m": { "token": "radius/semantic/small-elements", "value": 4 }
  },

  "border_width": {
    "focus": 2,
    "focus_token": "width/thick"
  },

  "font_family": null,

  "icon_source": {
    "library": "Material Symbols Outlined",
    "url": "https://fonts.google.com/icons",
    "icons": {
      "unchecked":     "check_box_outline_blank",
      "checked":       "check_box",
      "indeterminate": "indeterminate_check_box"
    },
    "params": "FILL@1; wght@400; GRAD@0; opsz@24"
  },

  "tokens": {
    "system/fg/primary":                       "#615fff",
    "system/fg/active":                        "#4f39f6",
    "system/fg/03":                            "#90a1b9",
    "system/fg/disabled":                      "#cad5e2",
    "system/border/interactive/focused":       "#615fff80",
    "system/overlays/overlay-hover-on-color":  "#0000001f",
    "system/overlays/overlay-active-on-color": "#00000033",
    "radius/semantic/small-elements":          "4",
    "radius/semantic/tiny-elements":           "2",
    "width/thick":                             "2"
  },

  "color_map": {
    "unchecked": {
      "idle":     "system/fg/03",
      "hover":    "system/fg/03 + overlay-hover-on-color",
      "pressed":  "system/fg/03 + overlay-active-on-color",
      "focused":  "system/fg/03",
      "disabled": "system/fg/disabled"
    },
    "checked": {
